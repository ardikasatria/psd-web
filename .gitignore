# Hanya push folder produksi + instruksi (bukan theme/demo lokal)
/*
!/.gitignore
!/deploy/
!/psd-frontend/
!/psd-backend/
!/psd-jupyterhub/
!/psd-superset/
!/Instructions/

# Dependencies
**/node_modules/

# Python virtual env
**/.venv/
**/venv/
**/ENV/

# Env rahasia (contoh .env.example tetap di-push)
.env
.env.*
!.env.example

# Build & cache
**/.next/
**/out/
**/__pycache__/
**/.pytest_cache/
*.py[cod]
*.tsbuildinfo

# OS
.DS_Store
