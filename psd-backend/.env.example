# Backend PSD — variabel lingkungan Fase 0
# Cocokkan dengan PSD_Checklist_Kesiapan_Rilis.md §2

# --- Inti / Auth ---
DATABASE_URL=postgresql+asyncpg://psd:psd@localhost:5432/psd
REDIS_URL=redis://localhost:6379/0
BACKEND_CORS_ORIGINS=["http://localhost:3000"]
JWT_SECRET=ganti-di-produksi
JWT_EXPIRE_MINUTES=1440

APP_BASE_URL=http://localhost:3000
COOKIE_NAME=psd_token
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
# COOKIE_DOMAIN=.projeksainsdata.com
DEV_EMAIL_ECHO=true

PSD_OFFICIAL_USERNAME=psd
TOS_VERSION=2026-06

# --- Storage MinIO/S3 (Langkah 13,15,38,40,41,45,46) ---
STORAGE_ENABLED=false
MINIO_ENDPOINT=localhost:9000
MINIO_KEY=psd
MINIO_SECRET=psd-secret
MINIO_BUCKET=psd-assets
MINIO_SECURE=false

S3_ENDPOINT_URL=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=psd
S3_SECRET_KEY=psd-secret
S3_MEDIA_BUCKET=psd-media
S3_PUBLIC_BASE_URL=http://localhost:9000/psd-media
S3_ASSETS_BUCKET=psd-assets
S3_ASSETS_PUBLIC_BASE_URL=http://localhost:9000/psd-assets
S3_SUBMISSIONS_BUCKET=psd-submissions

# --- Pencarian (Langkah 16) ---
MEILI_URL=http://localhost:7700
MEILI_KEY=psd-search-key

# --- AI (Langkah 38, 40) ---
OPENAI_API_KEY=
AI_MODEL=gpt-4o-mini

# --- Pabrik Data (Langkah 45) ---
FACTORY_RUN_TIMEOUT_S=90

# --- Celery (prod; dev memakai BackgroundTasks) ---
# CELERY_BROKER_URL=redis://localhost:6379/1
# CELERY_RESULT_BACKEND=redis://localhost:6379/2
