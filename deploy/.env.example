# Salin ke .env (atau jalankan: ./scripts/init-env.sh projeksainsdata.com)
# Jangan commit file .env — berisi rahasia produksi.
#
# Runbook lengkap: Instructions/PSD_Checklist_Kesiapan_Rilis.md
# Deploy VM: Instructions/Sudah/PSD_Deploy_VM.md

DOMAIN=projeksainsdata.com

# Postgres (stack Docker di VM)
POSTGRES_USER=psd
POSTGRES_PASSWORD=ganti-dengan-openssl-rand-hex-24
POSTGRES_DB=psd

# MinIO (S3-compatible) — bucket dibuat otomatis minio-init:
#   psd-assets (publik), psd-media (publik), psd-submissions (internal)
MINIO_ROOT_USER=psd
MINIO_ROOT_PASSWORD=ganti-dengan-openssl-rand-hex-24

# Auth & pencarian
JWT_SECRET=ganti-dengan-openssl-rand-hex-32
MEILI_KEY=ganti-dengan-openssl-rand-hex-24

# AI (Langkah 38, 40) — kosongkan jika fitur sintesis/ruang ide AI dimatikan sementara
OPENAI_API_KEY=
AI_MODEL=gpt-4o-mini

# Pabrik Data (Langkah 45)
FACTORY_RUN_TIMEOUT_S=90

# OAuth/OIDC Provider (Langkah 48) — kunci RSA dibuat otomatis via init-oauth-key.sh → secrets/psd_oidc.pem
PSD_OIDC_KEY_ID=psd-key-1

# Celery (Langkah 49 — prod aktif via docker-compose.prod.yml)
# CELERY_BROKER_URL=redis://localhost:6379/1
# CELERY_RESULT_BACKEND=redis://localhost:6379/2
# PSD_USE_CELERY=true

# Gitea (Langkah 50)
GITEA_DB_PASSWORD=ganti-dengan-openssl-rand-hex-24
GITEA_ADMIN_TOKEN=

# JupyterHub (Langkah 52) — service jupyterhub selalu ikut ./scripts/deploy.sh
# HUB_OIDC_SECRET: salin dari output seed-oauth-clients (client jupyterhub), lalu deploy ulang
HUB_OIDC_SECRET=
JUPYTERHUB_CRYPT_KEY=ganti-dengan-openssl-rand-hex-32

# Superset (Langkah 53)
SUPERSET_DB_PASSWORD=ganti-dengan-openssl-rand-hex-24
SUPERSET_SECRET_KEY=ganti-dengan-openssl-rand-hex-32
SUPERSET_GUEST_JWT_SECRET=ganti-dengan-openssl-rand-hex-32
SUPERSET_SERVICE_USER=psd_service
SUPERSET_SERVICE_PASSWORD=ganti-dengan-openssl-rand-hex-24
BI_OIDC_SECRET=
SUPERSET_GOLD_DB_ID=1

# Spark pipeline (Langkah 54 — opsional; aktifkan worker-spark profile)
PSD_SPARK_ENABLED=false
PSD_SPARK_MASTER=local[*]

# MLflow (Langkah 55)
MLFLOW_DB_PASSWORD=ganti-dengan-openssl-rand-hex-24
PSD_MLFLOW_ENABLED=false

# Serving model (Langkah 56 — butuh MLflow aktif)
PSD_SERVING_ENABLED=false
PSD_SERVING_REDIS_QUOTA=true

# AI Asisten (Langkah 57 — butuh OPENAI_API_KEY)
PSD_ASSISTANT_ENABLED=false
PSD_ASSISTANT_REDIS_QUOTA=true

# Cache & performa (Langkah 58 — reaktif)
PSD_PERF_ENABLED=true
PSD_PERF_CACHE_ENABLED=false
PSD_PERF_CACHE_AUTO=true
PSD_PERF_REDIS=true

# Email SMTP / Resend (Langkah 59–60)
# Auth (verifikasi/reset): cukup RESEND_API_KEY + PSD_EMAIL_SENDER
# Notifikasi aktivitas: set juga PSD_EMAIL_ENABLED=true
PSD_EMAIL_ENABLED=false
PSD_EMAIL_PROVIDER=http
# smtp | http — http (API Resend) lebih andal di Docker; SMTP: port 587 STARTTLS atau 465 + PSD_EMAIL_SMTP_SSL=true
PSD_EMAIL_SENDER=no-reply@projeksainsdata.com
RESEND_API_KEY=
PSD_EMAIL_SMTP_HOST=smtp.resend.com
PSD_EMAIL_SMTP_PORT=587
PSD_EMAIL_SMTP_USER=resend
PSD_EMAIL_SMTP_TLS=true
PSD_EMAIL_SMTP_SSL=false
PSD_EMAIL_UNSUBSCRIBE_SECRET=
PSD_EMAIL_REDIS=true

# Opsional — hanya docker-compose.local.yml (uji VM tanpa domain)
# VM_IP=192.168.x.x
