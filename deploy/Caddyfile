{$DOMAIN} {
    reverse_proxy frontend:3000
}

www.{$DOMAIN} {
    redir https://{$DOMAIN}{uri} permanent
}

app.{$DOMAIN} {
    redir https://{$DOMAIN}{uri} permanent
}

api.{$DOMAIN} {
    # MinIO path-style (bucket di URL) — pakai sertifikat api.* yang sudah aktif
    handle /psd-media/* {
        reverse_proxy minio:9000
    }
    handle /psd-assets/* {
        reverse_proxy minio:9000
    }
    handle {
        reverse_proxy backend:8000 {
            transport http {
                read_timeout 3m
                write_timeout 3m
            }
        }
    }
}

# Opsional: subdomain khusus storage (butuh sertifikat TLS terpisah di Caddy)
storage.{$DOMAIN} {
    reverse_proxy minio:9000
}

git.{$DOMAIN} {
    reverse_proxy gitea:3000
}

hub.{$DOMAIN} {
    reverse_proxy jupyterhub:8000 {
        transport http {
            read_timeout 5m
            write_timeout 5m
        }
    }
}

bi.{$DOMAIN} {
    reverse_proxy superset:8088
}

ml.{$DOMAIN} {
    reverse_proxy mlflow:5000
}
