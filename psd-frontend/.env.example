# Frontend PSD — variabel build-time (NEXT_PUBLIC_*)
# Produksi: NEXT_PUBLIC_USE_MOCKS=false + API nyata (lihat deploy/docker-compose.prod.yml)

NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_USE_MOCKS=true
NEXT_PUBLIC_APP_NAME=Projek Sains Data
# URL publik frontend (public/robots.txt, public/sitemap.xml, Open Graph). Produksi: https://projeksainsdata.com
# Regenerasi: npm run generate:sitemap
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Jupyter Notebook (Langkah 52) — kosongkan jika belum di-deploy
NEXT_PUBLIC_HUB_URL=https://hub.projeksainsdata.com

# Dev nyata (tanpa mock): salin ke .env.local
# NEXT_PUBLIC_USE_MOCKS=false
# NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
