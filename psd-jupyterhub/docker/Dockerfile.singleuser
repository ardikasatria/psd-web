FROM quay.io/jupyter/scipy-notebook:latest

USER root
USER ${NB_UID}

RUN pip install --no-cache-dir \
    pandas numpy scikit-learn matplotlib seaborn duckdb pyarrow httpx

COPY docker/jupyter_server_config.py /home/jovyan/.jupyter/jupyter_server_config.py

COPY app/psd_sdk /opt/psd/psd
ENV PYTHONPATH=/opt/psd:${PYTHONPATH}
